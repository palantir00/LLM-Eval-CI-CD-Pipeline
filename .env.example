# Environment variable template.
# Copy this file to `.env` and fill in the values:  cp .env.example .env
# The `.env` file is in .gitignore and must NEVER be committed to the repository.

# OpenAI API key. Required ONLY in "openai" mode (real model calls).
# "mock" mode works WITHOUT this key — this is intentional (see src/pipeline/llm_client.py),
# so that local development and CI are free.
OPENAI_API_KEY=sk-your-key-here

# LLM client mode: "mock" (default, zero cost) or "openai" (real API).
LLM_MODE=mock

# Default model used in "openai" mode.
OPENAI_MODEL=gpt-4o-mini