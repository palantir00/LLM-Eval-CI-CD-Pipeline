# Szablon zmiennych środowiskowych.
# Skopiuj ten plik do `.env` i uzupełnij wartości:  cp .env.example .env
# Plik `.env` jest w .gitignore i NIGDY nie trafia do repozytorium.

# Klucz API do OpenAI. Wymagany TYLKO w trybie "openai" (prawdziwe wywołania modelu).
# Tryb "mock" działa BEZ tego klucza — to celowy design (zob. src/pipeline/llm_client.py),
# żeby lokalny development i CI były darmowe.
OPENAI_API_KEY=sk-twoj-klucz-tutaj

# Tryb klienta LLM: "mock" (domyślny, zero kosztów) lub "openai" (prawdziwe API).
LLM_MODE=mock

# Domyślny model używany w trybie "openai".
OPENAI_MODEL=gpt-4o-mini